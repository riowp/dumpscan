<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.BarcodeScanner" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">@color/purple_700</item>
    </style>

    <style name="Theme.BarcodeScanner.NoActionBar" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#1A237E</item>
        <item name="android:statusBarColor">#1A237E</item>
        <item name="android:windowBackground">#1A237E</item>
    </style>

    <!-- Theme khusus agar teks input selalu hitam di background putih (scan screen) -->
    <style name="LightInputTheme" parent="Theme.MaterialComponents.Light">
        <item name="colorOnSurface">#212121</item>
        <item name="colorPrimary">#1565C0</item>
        <item name="android:textColorPrimary">#212121</item>
        <item name="android:textColorHint">#757575</item>
    </style>
</resources>
