<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardRoot"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginBottom="6dp" app:cardCornerRadius="8dp" app:cardElevation="2dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Strip merah di kiri sebagai penanda remark (visible hanya jika hasRemark) -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Garis penanda remark di sisi kiri -->
            <View android:id="@+id/viewRemarkStrip"
                android:layout_width="4dp" android:layout_height="match_parent"
                android:background="#E65100" android:visibility="gone" />

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:padding="10dp">

                <!-- Row 1: No + Tiket + Shift -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:id="@+id/tvNo" android:layout_width="28dp"
                        android:layout_height="wrap_content" android:textSize="12sp" android:textColor="#90A4AE" />
                    <TextView android:id="@+id/tvTicket" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:textSize="14sp" android:textStyle="bold" android:textColor="#1A237E"
                        android:paddingStart="4dp" />
                    <TextView android:id="@+id/tvShift" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:paddingHorizontal="8dp"
                        android:paddingVertical="3dp" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="#FFFFFF" android:background="@drawable/badge_shift" />
                </LinearLayout>

                <!-- Row 2: Tonnase efektif + coret asli + Stockpile + Sync -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="4dp" android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <!-- Tonnage efektif (remark jika ada, normal jika tidak) -->
                        <TextView android:id="@+id/tvTonnage" android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="13sp" android:textColor="#2E7D32" android:textStyle="bold" />
                        <!-- Tonnage asli dari tiket (hanya tampil jika ada remark) -->
                        <TextView android:id="@+id/tvTonnageOriginal" android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="10sp" android:textColor="#9E9E9E"
                            android:visibility="gone" />
                    </LinearLayout>
                    <TextView android:id="@+id/tvStockpile" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textSize="11sp"
                        android:textColor="#FFFFFF" android:background="#FF6F00"
                        android:paddingHorizontal="6dp" android:paddingVertical="2dp"
                        android:layout_marginEnd="6dp" />
                    <TextView android:id="@+id/tvSyncStatus" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textSize="10sp" android:layout_marginEnd="4dp" />
                </LinearLayout>

                <!-- Row 3: Keterangan remark (hanya tampil jika ada remark) -->
                <LinearLayout android:id="@+id/layoutRemarkInfo"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginTop="3dp" android:visibility="gone">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⚠ Remark: " android:textSize="10sp"
                        android:textColor="#E65100" android:textStyle="bold" />
                    <TextView android:id="@+id/tvRemarkNote" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:textSize="10sp" android:textColor="#BF360C" android:textStyle="italic" />
                </LinearLayout>

                <!-- Row 4: Operator + Waktu -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="2dp" android:gravity="center_vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="👷 " android:textSize="10sp" />
                    <TextView android:id="@+id/tvOperator" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:textSize="10sp" android:textColor="#546E7A" />
                    <TextView android:id="@+id/tvTime" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textSize="10sp"
                        android:textColor="#90A4AE" />
                </LinearLayout>

                <!-- Row 5: Edit + Hapus -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="8dp">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEdit" android:layout_width="0dp" android:layout_height="36dp"
                        android:layout_weight="1" android:layout_marginEnd="4dp" android:text="✏ Edit"
                        android:textSize="12sp" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:strokeColor="#1565C0" android:textColor="#1565C0" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDelete" android:layout_width="0dp" android:layout_height="36dp"
                        android:layout_weight="1" android:layout_marginStart="4dp" android:text="🗑 Hapus"
                        android:textSize="12sp" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:strokeColor="#C62828" android:textColor="#C62828" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
